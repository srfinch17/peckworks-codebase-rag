{
  "name": "peckworks-codebase-rag",
  "version": "0.1.0",
  "description": "Generic code-aware RAG: point it at any repo, ask questions, get grounded, cited answers. One tool, many indexes (one Qdrant collection per repo).",
  "type": "module",
  "scripts": {
    "ingest": "tsx src/cli/index.ts ingest",
    "ask": "tsx src/cli/index.ts ask",
    "web": "tsx src/web/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "qdrant:up": "docker compose up -d",
    "qdrant:down": "docker compose down",
    "logs:reset": "node -e \"require('fs').writeFileSync('logs/events.jsonl','')\""
  },
  "keywords": ["rag", "code-search", "vector-search", "embeddings", "qdrant", "anthropic", "claude"],
  "author": "Peckworks Lab",
  "license": "ISC",
  "overrides": {
    "undici": "^8.2.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@qdrant/js-client-rest": "^1.12.0",
    "@xenova/transformers": "^2.17.2",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
