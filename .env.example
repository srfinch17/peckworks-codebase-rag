# Copy to .env and fill in.

# Required for the ANSWER step (step 5) only. Embedding/ingest run offline.
ANTHROPIC_API_KEY=sk-ant-...

# Qdrant (the vector DB). Default matches docker-compose.yml.
QDRANT_URL=http://localhost:6333

# Embeddings: default is a LOCAL model via Transformers.js (no API key needed).
EMBEDDER=local
